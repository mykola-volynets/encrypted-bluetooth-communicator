<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>BluetoothTransferWidget</class>
 <widget class="QWidget" name="BluetoothTransferWidget">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>480</width>
    <height>600</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>Bluetooth File Transfer</string>
  </property>
  <property name="styleSheet">
   <string notr="true">QWidget {
    background-color: #f0f0f0;
    font-family: "Segoe UI", sans-serif;
    font-size: 10pt;
   }
   QGroupBox {
    background-color: #ffffff;
    border: 1px solid #c0c0c0;
    border-radius: 5px;
    margin-top: 1em;
   }
   QGroupBox::title {
    subcontrol-origin: margin;
    left: 10px;
    padding: 0 5px;
    color: #555;
   }
   QPushButton {
    background-color: #007bff;
    color: white;
    border: none;
    border-radius: 5px;
    padding: 8px 15px;
    font-weight: bold;
   }
   QPushButton:hover {
    background-color: #0056b3;
   }
   QPushButton:disabled {
    background-color: #6c757d;
    color: #fff;
   }
   QListWidget {
    border: 1px solid #c0c0c0;
    border-radius: 3px;
    background-color: #fff;
   }
   QListWidget::item:selected {
    background-color: #e0f7fa;
    color: #333;
   }
   QLineEdit {
    border: 1px solid #c0c0c0;
    border-radius: 3px;
    padding: 6px;
    background-color: #fff;
   }
   QLabel {
    color: #333;
   }
   QProgressBar {
    border: 1px solid #c0c0c0;
    border-radius: 5px;
    text-align: center;
    background-color: #e9ecef;
    color: #333;
   }
   QProgressBar::chunk {
    background-color: #28a745;
    border-radius: 4px;
   }
   QTextEdit {
    border: 1px solid #c0c0c0;
    border-radius: 3px;
    background-color: #fff;
    font-family: "Consolas", monospace;
    font-size: 9pt;
   }
  </string>
  </property>
  <layout class="QVBoxLayout" name="mainLayout">
   <item>
    <widget class="QGroupBox" name="connectionGroupBox">
     <property name="title">
      <string>1. Connection</string>
     </property>
     <layout class="QGridLayout" name="connectionLayout">
      <item row="0" column="0">
       <widget class="QPushButton" name="scanButton">
        <property name="toolTip">
         <string>Scan for nearby discoverable Bluetooth devices</string>
        </property>
        <property name="text">
         <string>Scan Devices</string>
        </property>
       </widget>
      </item>
      <item row="1" column="0" colspan="2">
       <widget class="QListWidget" name="deviceListWidget">
        <property name="toolTip">
         <string>List of discovered Bluetooth devices (Name - Address)</string>
        </property>
       </widget>
      </item>
      <item row="2" column="0">
       <widget class="QPushButton" name="connectButton">
        <property name="enabled">
         <bool>false</bool>
        </property>
        <property name="toolTip">
         <string>Connect to the selected device in the list</string>
        </property>
        <property name="text">
         <string>Connect</string>
        </property>
       </widget>
      </item>
      <item row="3" column="0" colspan="2">
       <widget class="QLabel" name="statusLabel">
        <property name="text">
         <string>Status: Disconnected</string>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="fileTransferGroupBox">
     <property name="title">
      <string>2. File Transfer</string>
     </property>
     <layout class="QGridLayout" name="fileLayout">
      <item row="0" column="0">
       <widget class="QPushButton" name="selectFileButton">
        <property name="toolTip">
         <string>Choose a file to send</string>
        </property>
        <property name="text">
         <string>Select File</string>
        </property>
       </widget>
      </item>
      <item row="0" column="1">
       <widget class="QLineEdit" name="filePathLineEdit">
        <property name="readOnly">
         <bool>true</bool>
        </property>
        <property name="toolTip">
         <string>Path of the selected file</string>
        </property>
        <property name="placeholderText">
         <string>No file selected</string>
        </property>
       </widget>
      </item>
      <item row="1" column="0" colspan="2">
       <widget class="QPushButton" name="sendButton">
        <property name="enabled">
         <bool>false</bool>
        </property>
        <property name="toolTip">
         <string>Send the selected file to the connected device</string>
        </property>
        <property name="text">
         <string>Send File</string>
        </property>
       </widget>
      </item>
      <item row="2" column="0" colspan="2">
       <widget class="QProgressBar" name="progressBar">
        <property name="toolTip">
         <string>File transfer progress</string>
        </property>
        <property name="value">
         <number>0</number>
        </property>
        <property name="textVisible">
         <bool>true</bool>
        </property>
        <property name="alignment">
         <set>Qt::AlignCenter</set>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
   <item>
    <widget class="QGroupBox" name="logGroupBox">
     <property name="title">
      <string>Logs</string>
     </property>
     <layout class="QVBoxLayout" name="logLayout">
      <item>
       <widget class="QTextEdit" name="logTextEdit">
        <property name="readOnly">
         <bool>true</bool>
        </property>
       </widget>
      </item>
     </layout>
    </widget>
   </item>
  </layout>
 </widget>
